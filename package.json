{
  "name": "tetraforce-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.1.5"
  },
  "scripts": {
    "dev": "npm run dev --workspace @tetraforce/web",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace @tetraforce/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
